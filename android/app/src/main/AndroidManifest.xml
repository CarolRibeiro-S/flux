<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"></meta-data>
        </provider>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- NÃO declarar android.permission.CAMERA aqui.
         Este app é uma WebView que só carrega a URL da Vercel e usa
         <input type="file"> puro (não o plugin de câmera do Capacitor).
         Quando CAMERA está declarada no manifest, o BridgeWebChromeClient do
         Capacitor passa a tratar o input pela rota de "captura de mídia", que
         exige a permissão concedida em runtime — e como não há código nativo
         pedindo essa permissão, o seletor de arquivos simplesmente NÃO ABRE
         (foi o que quebrou o botão "Escolher da galeria").
         Sem a permissão: a galeria abre normalmente, e o "Tirar foto"
         (capture="environment") continua funcionando por delegação ao app de
         câmera do sistema, que tem a permissão própria dele. -->

    <!-- Câmera é opcional (a usuária pode escolher da galeria em vez de
         fotografar), então o app não deve sumir da Play Store para aparelhos
         sem câmera física (ex: alguns tablets). -->
    <uses-feature android:name="android.hardware.camera" android:required="false" />
</manifest>
